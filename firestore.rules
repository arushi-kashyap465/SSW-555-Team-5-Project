rules_version = '2';

// The client never talks to Firestore directly — all reads and writes go
// through the Cloud Functions backend (Admin SDK, which bypasses these
// rules). So we deny everything from the client SDK, which is the
// secure default for a "demo use" application.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
