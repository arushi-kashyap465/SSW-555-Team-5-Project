{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "backend",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "src/testing/**"
      ]
    }
  ],
  "hosting": {
    "public": "frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/scan", "destination": "/scan.html" },
      { "source": "/dashboard", "destination": "/dashboard.html" }
    ],
    "cleanUrls": true
  },
  "emulators": {
    "functions": { "host": "127.0.0.1", "port": 5001 },
    "firestore": { "host": "127.0.0.1", "port": 8085 },
    "hosting":   { "host": "127.0.0.1", "port": 5002 },
    "ui":        { "enabled": true, "host": "127.0.0.1", "port": 4001 },
    "singleProjectMode": true
  }
}
